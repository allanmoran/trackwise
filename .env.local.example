# TrackWise Environment Configuration
# Copy to .env.local and customize for your environment

# API Server
VITE_API_URL=http://localhost:3001

# Optional: Feature flags
VITE_DEBUG=true
VITE_ENABLE_OFFLINE=false

# Optional: Analytics/Telemetry (future use)
# VITE_ANALYTICS_ENABLED=false
# VITE_SENTRY_DSN=

# Note: .env.local is git-ignored and not committed
# This file (.env.local.example) is committed as reference
