{
  "name": "trackwise-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node src/scripts/seed-kb.js",
    "enrich": "node src/scripts/enrich-kb.js",
    "load": "node src/scripts/load-real-data.js",
    "test-cloud": "node src/scripts/test-cloud-connection.js",
    "recover": "node src/scripts/recover-from-cloud.js",
    "recover-bets": "node src/scripts/recover-bets-only.js",
    "scrape-punters": "node src/scripts/scrape-punters-form.js",
    "extract-jockeys": "node src/scripts/extract-punters-jockeys.js",
    "extract-trainers": "node src/scripts/extract-punters-trainers.js",
    "extract-horses": "node src/scripts/extract-punters-horses.js",
    "extract-punters": "npm run extract-jockeys && npm run extract-trainers && npm run extract-horses",
    "backup-kb": "node src/scripts/backup-kb.js",
    "backup-kb-cloud": "node src/scripts/backup-kb.js --cloud"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "papaparse": "^5.4.1",
    "postgres": "^3.4.9",
    "puppeteer": "^21.11.0"
  }
}
